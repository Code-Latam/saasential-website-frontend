---
import {portfolios as port} from '../../data/portfolios';
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';
import SEO from "../../components/SEO.astro";

export async function getStaticPaths() {
    return port.map((portfolio) => ({
        params: { slug: portfolio.slug },
        props: { portfolios: portfolio },
    }));
}
const { portfolios } = Astro.props;
---
<SEO
        title={`${portfolios.title}`}
        description={portfolios.shortDesc}
        keywords={`${portfolios.category}, Saasential, SaaS development, FinTech solutions, software consulting, cloud architecture, API automation`}
        image={portfolios.image}
        url={`https://www.saasential.tech/our-work/${portfolios.slug}`}
/>
<PortfolioLayout {portfolios} />