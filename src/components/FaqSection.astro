---
// src/components/FAQ.astro
import { faqContent } from '../content/content.ts';
---

<section id="faqs" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
        <!-- Header -->
        <div class="flex justify-between items-center mb-12 portfolio-header">
            <div>
                <div class="flex items-center gap-2 mb-3" data-aos="fade-up" data-aos-delay="100">
                    <span class="text-blue-400 text-lg">✱</span>
                    <span class="text-blue-400 font-semibold tracking-wide uppercase text-sm">
                        {faqContent.header.badge}
                    </span>
                    <span class="text-blue-400 text-lg">✱</span>
                </div>
                <h2 class="text-5xl font-bold text-gray-900" data-aos="fade-up" data-aos-delay="200">
                    {faqContent.header.title}
                </h2>
                <p class="mt-4 text-gray-600 text-lg mx-auto" data-aos="fade-up" data-aos-delay="300">
                    {faqContent.header.subtitle}
                </p>
            </div>
        </div>

        <!-- FAQ Items -->
        <div class="space-y-4 max-w-6xl">
            {faqContent.faqs.map((faq, index) => (
                    <details
                            class="group border border-blue-200 bg-white rounded-2xl shadow-sm transition-all duration-300 hover:shadow-md"
                            data-aos="fade-up"
                            data-aos-delay={400 + index * 100}
                    >
                        <summary
                                class="cursor-pointer list-none px-6 py-4 flex justify-between items-center text-left font-semibold text-gray-900 hover:text-blue-600 transition-colors"
                        >
                            <span class="pr-4">{faq.question}</span>
                            <svg
                                    class="w-5 h-5 text-blue-600 transition-transform duration-300 group-open:rotate-180 flex-shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                            >
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                            </svg>
                        </summary>
                        <div class="px-6 pb-5 text-gray-600 leading-relaxed whitespace-pre-line">
                            {faq.answer}
                            {
                                faq.highlight && (
                                            <a href={faq.link} class="text-blue-600 font-semibold hover:underline mt-2 inline-block cursor-pointer">
                                                {faq.highlight}
                                            </a>
                                )

                            }
                            {
                                faq.continuation &&(
                                            <span>
                                            {faq.continuation}
                                        </span>
                                )
                            }
                        </div>
                    </details>
            ))}
        </div>
    </div>
</section>

<style>
    section {
        scroll-margin-top: 80px;
    }

    /* AOS Animations */
    [data-aos] {
        opacity: 0;
        transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    [data-aos="fade-up"] {
        transform: translateY(40px);
    }

    [data-aos="fade-down"] {
        transform: translateY(-40px);
    }

    [data-aos="fade-left"] {
        transform: translateX(40px);
    }

    [data-aos="fade-right"] {
        transform: translateX(-40px);
    }

    [data-aos].aos-animate {
        opacity: 1;
        transform: translateY(0) translateX(0);
    }

    /* Smooth scrolling */
    html {
        scroll-behavior: smooth;
    }

    /* Smooth details transition */
    details {
        overflow: hidden;
    }

    details[open] summary {
        border-bottom: 1px solid #e5e7eb;
        margin-bottom: 1rem;
        padding-bottom: 1rem;
    }

    /* Remove default marker */
    summary::-webkit-details-marker {
        display: none;
    }

    /* Better line breaks for bullet points */
    .whitespace-pre-line {
        white-space: pre-line;
    }

</style>

<script>
    // Enhanced intersection observer with stagger effect
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const delay = entry.target.getAttribute('data-aos-delay') || 0;
                    setTimeout(() => {
                        entry.target.classList.add('aos-animate');
                    }, parseInt(delay));
                }
            });
        },
        {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        }
    );

    document.querySelectorAll('[data-aos]').forEach((el) => observer.observe(el));
</script>