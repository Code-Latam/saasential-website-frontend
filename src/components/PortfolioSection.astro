---
import PortfolioCard from "./PortfolioCard.astro";
import { Swiper, SwiperWrapper, SwiperSlide } from "astro-swiper";
import jobposting from "../assets/portfolios/jobposting_banner_1.png"
import lucii from "../assets/portfolios/lucii_banner.png"
import weatherapp from "../assets/portfolios/weather_banner_1.png"
import wonomin from "../assets/portfolios/wonomin_banner_1.png"
import tictactoe from "../assets/portfolios/tictactoe_banner_1.png"
import siptouch from "../assets/portfolios/siptouch_banner_1.png"
---

<section class="py-20 bg-white overflow-hidden" id="portfolio">
    <div class="max-w-7xl mx-auto px-4">
        <!-- Header -->
        <div class="flex justify-between items-center mb-12 portfolio-header">
            <div>
                <div class="flex items-center gap-2 mb-3 fade-in-up" style="animation-delay: 0.1s;">
                    <span class="text-blue-400 text-lg">✱</span>
                    <span class="text-blue-400 font-semibold tracking-wide uppercase text-sm">Visual Excellence</span>
                    <span class="text-blue-400 text-lg">✱</span>
                </div>
                <h2 class="text-5xl font-bold text-gray-900 fade-in-up" style="animation-delay: 0.2s;">
                    Our Creative Showcase
                </h2>
            </div>
            <a
                    href="#all-portfolio"
                    class="hidden md:block px-8 py-3 bg-blue-400 hover:bg-blue-600 text-white font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:scale-105 fade-in-up"
                    style="animation-delay: 0.3s;"
            >
                View All Portfolio
            </a>
        </div>

        <!-- Swiper Slider -->
        <div class="fade-in-up" style="animation-delay: 0.4s;">
            <Swiper
                    class="portfolio-swiper pb-20"
                    options={{
                        slidesPerView: 1,
                        spaceBetween: 30,
                        breakpoints: {
                            640: {
                                slidesPerView: 1.5,
                                spaceBetween: 20,
                            },
                            768: {
                                slidesPerView: 2,
                                spaceBetween: 25,
                            },
                            1024: {
                                slidesPerView: 3,
                                spaceBetween: 30,
                            },
                        },
                        pagination: {
                            el: '.swiper-pagination',
                            clickable: true,
                            renderBullet: function (index, className) {
                                return '<span class="' + className + '"></span>';
                            },
                        },
                        loop: true,
                        speed: 800,
                        autoplay: {
                            delay: 4000,
                            disableOnInteraction: false,
                        },
                        effect: 'slide',
                    }}
            >
                <SwiperWrapper>
                    <SwiperSlide>
                        <PortfolioCard
                                title="Bridging Traditional Finance with Cryptocurrency Trading"
                                category="Cryptocurrency"
                                image={jobposting}
                                link="#"
                        />
                    </SwiperSlide>

                    <SwiperSlide>
                        <PortfolioCard
                                title="Elevating Boardroom Media's Digital Presence"
                                category="Entertainment & Media"
                                image={lucii}
                                link="#"
                        />
                    </SwiperSlide>

                    <SwiperSlide>
                        <PortfolioCard
                                title="Unified Platform for Crypto Transactions"
                                category="Cryptocurrency"
                                image={weatherapp}
                                link="#"
                        />
                    </SwiperSlide>

                    <SwiperSlide>
                        <PortfolioCard
                                title="Modern Banking Experience Reimagined"
                                category="FinTech"
                                image={wonomin}
                                link="#"
                        />
                    </SwiperSlide>

                    <SwiperSlide>
                        <PortfolioCard
                                title="AI-Powered Customer Engagement Platform"
                                category="Artificial Intelligence"
                                image={tictactoe}
                                link="#"
                        />
                    </SwiperSlide>

                    <SwiperSlide>
                        <PortfolioCard
                                title="Secure Payment Gateway Solution"
                                category="FinTech"
                                image={siptouch}
                                link="#"
                        />
                    </SwiperSlide>

                </SwiperWrapper>
            </Swiper>

            <!-- Custom Pagination Indicators -->
            <div class="flex justify-center mt-8">
                <div class="swiper-pagination !relative !bottom-0"></div>
            </div>
        </div>

        <!-- Mobile View All Button -->
        <div class="md:hidden text-center mt-8 fade-in-up" style="animation-delay: 0.5s;">
            <a
                    href="#all-portfolio"
                    class="inline-block px-8 py-3 bg-blue-400 hover:bg-blue-600 text-white font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:scale-105"
            >
                View All Portfolio
            </a>
        </div>
    </div>
</section>

<style>
    /* Fade in up animation */
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fade-in-up {
        animation: fadeInUp 0.8s ease-out forwards;
        opacity: 0;
    }

    /* Custom Swiper Pagination Styling */
    :global(.swiper-pagination) {
        position: relative !important;
        bottom: 0 !important;
        display: flex !important;
        justify-content: center !important;
        align-items: center !important;
        gap: 12px !important;
        margin-top: 2rem !important;
    }

    :global(.swiper-pagination-bullet) {
        width: 16px !important;
        height: 16px !important;
        background: white !important;
        opacity: 1 !important;
        transition: all 0.4s ease !important;
        border-radius: 50% !important;
        cursor: pointer !important;
        margin: 0 !important;
        border: 3px solid #64748b !important;
    }

    :global(.swiper-pagination-bullet:hover) {
        border-color: #475569 !important;
        transform: scale(1.2) !important;
    }

    :global(.swiper-pagination-bullet-active) {
        background: #51a2ff !important;
        border-color: #51a2ff !important;
        width: 50px !important;
        border-radius: 10px !important;
        transform: scale(1) !important;
    }

    /* Smooth slide transitions */
    :global(.portfolio-swiper .swiper-slide) {
        transition: transform 0.3s ease, opacity 0.3s ease;
    }

    :global(.portfolio-swiper .swiper-slide-active) {
        z-index: 2;
    }

    /* Add subtle animation on slide change */
    @keyframes slideIn {
        from {
            opacity: 0.5;
            transform: scale(0.95);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    :global(.portfolio-swiper .swiper-slide-active > *) {
        animation: slideIn 0.6s ease-out;
    }
</style>

<script>
    // Add intersection observer for scroll animations
    if (typeof window !== 'undefined') {
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.animationPlayState = 'running';
                }
            });
        }, observerOptions);

        document.addEventListener('DOMContentLoaded', () => {
            const animatedElements = document.querySelectorAll('.fade-in-up');
            animatedElements.forEach(el => {
                observer.observe(el);
            });
        });
    }
</script>