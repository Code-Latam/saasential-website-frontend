---
// Navbar.astro
import { services } from "../data/services.js";  // Added .js extension
import { Image } from 'astro:assets';
import logo from "../../public/logo/saasential_logo.png";
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 ease-in-out">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <div class="flex-shrink-0 animate-fade-in">
                <a href="/" class="flex items-center space-x-2 group">
                    <Image 
                    src={logo} 
                    alt="Saasential Logo" 
                    class="h-16 w-auto object-contain transform transition-transform group-hover:scale-110"
                    />
                </a>
            </div>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center space-x-8 animate-fade-in-delay">
                <a href="/" class="nav-link text-white hover:text-blue-400 transition-all duration-200 font-medium relative group">
                    <span>Home</span>
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 transition-all duration-300 group-hover:w-full"></span>
                </a>

                <!-- Services Dropdown -->
                <div class="relative group">
                    <a href="/services" class="nav-link text-white hover:text-blue-400 transition-all duration-200 font-medium flex items-center space-x-1 cursor-pointer relative">
                        <span>Services</span>
                        <svg class="w-4 h-4 transform transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 transition-all duration-300 group-hover:w-full"></span>
                    </a>

                    <!-- Dropdown Menu -->
                    <div class="absolute left-0 mt-3 w-72 opacity-0 invisible group-hover:opacity-100 group-hover:visible transform scale-95 group-hover:scale-100 transition-all duration-300 bg-white rounded-xl shadow-2xl border border-gray-100 py-2 backdrop-blur-lg overflow-hidden">
                        <div class="px-4 py-3 border-b border-gray-100">
                            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Our Services</p>
                        </div>

                        {services && services.map((service, i) => (
                            <a
                                href={"/services/" + service.slug}
                                class="dropdown-item flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gradient-to-r hover:from-blue-50 hover:to-indigo-50 transition-all duration-300 group/item"
                                style={`animation-delay: ${i * 50}ms`}
                            >
                                <div class="flex-1">
                                    <div class="font-medium text-gray-900 group-hover/item:text-blue-600 transition-colors">
                                        {service.title}
                                    </div>
                                </div>
                            </a>
                        ))}
                    </div>
                </div>

                <a href="/our-work" class="nav-link text-white hover:text-blue-400 transition-all duration-200 font-medium relative group">
                    <span>Our Work</span>
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 transition-all duration-300 group-hover:w-full"></span>
                </a>

                <a href="/blog" class="nav-link text-white hover:text-blue-400 transition-all duration-200 font-medium relative group">
                    <span>Blog</span>
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 transition-all duration-300 group-hover:w-full"></span>
                </a>

                <a href="/contact" class="nav-link text-white hover:text-blue-400 transition-all duration-200 font-medium relative group">
                    <span>Contact</span>
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 transition-all duration-300 group-hover:w-full"></span>
                </a>
            </div>

            <div class="flex-wrap"></div>
            
            <!-- Mobile Menu Button -->
            <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-white/10 transition-all duration-200 animate-fade-in">
                <svg id="menu-icon" class="w-6 h-6 text-white transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path id="menu-icon-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 bg-white/95 backdrop-blur-lg shadow-2xl max-h-screen overflow-y-auto">
        <div class="px-4 py-4 space-y-2 animate-slide-down">
            <a href="/" class="mobile-link block px-4 py-3 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-all duration-200 font-medium transform hover:translate-x-2">
                Home
            </a>

            <!-- Services Expandable Section -->
            <div class="mobile-link">
                <button
                    id="mobile-services-toggle"
                    class="w-full flex items-center justify-between px-4 py-3 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-all duration-200 font-medium"
                >
                    <span>Services</span>
                    <svg id="mobile-services-icon" class="w-5 h-5 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>

                <!-- Services Submenu -->
                <div id="mobile-services-menu" class="hidden mt-2 ml-4 space-y-2 border-l-2 border-blue-200 pl-4">
                    {services && services.map((service) => (
                        <a
                            href={"/services/" + service.slug}
                            class="block px-4 py-2.5 text-gray-600 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition-all duration-200 transform hover:translate-x-2"
                        >
                            {service.title}
                        </a>
                    ))}
                </div>
            </div>

            <a href="/our-work" class="mobile-link block px-4 py-3 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-all duration-200 font-medium transform hover:translate-x-2">
                Our Work
            </a>

            <a href="/blog" class="mobile-link block px-4 py-3 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-all duration-200 font-medium transform hover:translate-x-2">
                Blog
            </a>

            <a href="/contact" class="mobile-link block px-4 py-3 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-all duration-200 font-medium transform hover:translate-x-2">
                Contact
            </a>
        </div>
    </div>
</nav>

<style>
    /* Navbar styles */
    nav {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
    }

    /* Default navbar state - transparent */
    #navbar {
        background-color: transparent;
    }

    /* Scrolled navbar state - with enhanced shadow */
    #navbar.navbar-scrolled {
        background-color: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    #navbar.navbar-scrolled .nav-link,
    #navbar.navbar-scrolled a span {
        color: rgb(31, 41, 55) !important;
    }

    #navbar.navbar-scrolled a:hover span {
        color: rgb(37, 99, 235) !important;
    }

    #navbar.navbar-scrolled #menu-icon {
        color: rgb(31, 41, 55) !important;
    }

    /* Dropdown item animation */
    .dropdown-item {
        opacity: 0;
        transform: translateY(-10px);
        animation: fadeInDropdown 0.3s ease-out forwards;
    }

    @keyframes fadeInDropdown {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Animations */
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            max-height: 0;
        }
        to {
            opacity: 1;
            max-height: 1000px;
        }
    }

    .animate-fade-in {
        animation: fadeIn 0.6s ease-out forwards;
    }

    .animate-fade-in-delay {
        animation: fadeIn 0.6s ease-out 0.2s forwards;
        opacity: 0;
    }

    .animate-fade-in-up {
        animation: fadeInUp 0.5s ease-out forwards;
    }

    .animate-slide-down {
        animation: slideDown 0.3s ease-out forwards;
    }

    /* Smooth transitions */
    * {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    /* Mobile services menu animation */
    #mobile-services-menu {
        animation: slideDown 0.3s ease-out forwards;
    }
</style>

<script>
    // Navbar scroll effect
    const navbar = document.getElementById('navbar');

    window.addEventListener('scroll', () => {
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

        if (scrollTop > 50) {
            navbar?.classList.add('navbar-scrolled');
        } else {
            navbar?.classList.remove('navbar-scrolled');
        }
    });

    // Mobile menu toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIconPath = document.getElementById('menu-icon-path');

    mobileMenuBtn?.addEventListener('click', () => {
        const isHidden = mobileMenu?.classList.contains('hidden');

        if (isHidden) {
            mobileMenu?.classList.remove('hidden');
            menuIconPath?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
        } else {
            mobileMenu?.classList.add('hidden');
            menuIconPath?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
        }
    });

    // Mobile services toggle
    const mobileServicesToggle = document.getElementById('mobile-services-toggle');
    const mobileServicesMenu = document.getElementById('mobile-services-menu');
    const mobileServicesIcon = document.getElementById('mobile-services-icon');

    mobileServicesToggle?.addEventListener('click', () => {
        const isHidden = mobileServicesMenu?.classList.contains('hidden');

        if (isHidden) {
            mobileServicesMenu?.classList.remove('hidden');
            mobileServicesIcon?.classList.add('rotate-180');
        } else {
            mobileServicesMenu?.classList.add('hidden');
            mobileServicesIcon?.classList.remove('rotate-180');
        }
    });

    // Close mobile menu when clicking outside
    document.addEventListener('click', (e) => {
        const target = e.target;
        if (!target.closest('#mobile-menu') && !target.closest('#mobile-menu-btn')) {
            mobileMenu?.classList.add('hidden');
            menuIconPath?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
        }
    });
</script>