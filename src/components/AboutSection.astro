---
// About.astro
import {aboutContent} from "../content/content";
---


<section id="about" class="relative min-h-screen flex items-center bg-white text-gray-800 py-20 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">

            <!-- Left Content (Wider) -->
            <div class="lg:col-span-7 space-y-6">
                <div class="flex justify-between items-center mb-12">
                    <div>
                        <div class="flex items-center gap-2 mb-3 fade-in-up" style="animation-delay: 0.1s;">
                            <span class="text-blue-400 text-lg">✱</span>
                            <span class="text-blue-400 font-semibold tracking-wide uppercase text-sm">{aboutContent.badge.text}</span>
                            <span class="text-blue-400 text-lg">✱</span>
                        </div>
                        <h2 class="text-5xl font-bold text-gray-900 fade-in-up" style="animation-delay: 0.2s;">
                            {aboutContent.heading.main}
                        </h2>
                    </div>
                </div>

                <!-- First Paragraph -->
                <p class="text-gray-700 text-lg leading-relaxed">
                    At <span class="font-bold text-blue-600">{aboutContent.intro.companyName}</span>,
                    {aboutContent.intro.description}
                </p>


                <p class="text-gray-700 text-lg leading-relaxed">
                    {aboutContent.paragraphs[0].text} <span class="font-semibold text-blue-600">{aboutContent.paragraphs[0].highlight}</span> {aboutContent.paragraphs[0].continuation}
                </p>



                <!-- Second Paragraph -->
                <p class="text-gray-700 text-lg leading-relaxed">
                    {aboutContent.secondParagraph}
                </p>
            </div>

            <!-- Right Stats (Narrower) -->
            <div class="lg:col-span-5 flex flex-col justify-center space-y-12 mt-30 ">
                {aboutContent.stats.map((stat) => (
                        <div class="flex items-center space-x-6 group">
                            <!-- Icon Container -->
                            <div class="flex-shrink-0 w-20 h-20 bg-white border-2 border-blue-200 rounded-2xl flex items-center justify-center group-hover:border-blue-500 group-hover:shadow-xl transition-all duration-300">
                                {stat.icon === 'projects' && (
                                        <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                        </svg>
                                )}
                                {stat.icon === 'satisfaction' && (
                                        <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/>
                                        </svg>
                                )}
                                {stat.icon === 'experience' && (
                                        <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                )}
                            </div>

                            <!-- Stat Text -->
                            <div class="flex-1">
                                <div class="flex items-baseline space-x-1">
                                    <h3 class="text-5xl font-black text-gray-900 group-hover:text-blue-600 transition-colors duration-300">
                                        {stat.number}
                                    </h3>
                                    {stat.label && (
                                            <span class="text-3xl font-black text-gray-900 group-hover:text-blue-600 transition-colors duration-300">
                                        {stat.label}
                                    </span>
                                    )}
                                </div>
                                <p class="text-gray-600 text-base font-medium mt-1">
                                    {stat.sublabel}
                                </p>
                            </div>
                        </div>
                ))}
            </div>
        </div>
    </div>
</section>

<style>
    section {
        scroll-margin-top: 80px;
    }

    /* Subtle animation on scroll */
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>