---
import { Icon } from "astro-icon/components";

const footerLinks = [
    { name: "About", href: "#about" },
    { name: "Services", href: "#services" },
    { name: "Portfolio", href: "#portfolio" },
    { name: "Contact", href: "#contact" },
];

const socials = [
    { name: "LinkedIn", icon: "fa7-brands:linkedin", href: "#" },
    { name: "Twitter", icon: "fa7-brands:x-twitter", href: "#" },
    { name: "GitHub", icon: "fa7-brands:github", href: "#" },
    { name: "Instagram", icon: "fa7-brands:instagram", href: "#" },
];
---

<footer class="relative bg-gradient-to-b from-gray-900 via-gray-900 to-black text-gray-300 overflow-hidden">
    <!-- Animated background grid -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-20"></div>

    <!-- Gradient orbs -->
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-indigo-600/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

    <div class="relative max-w-7xl mx-auto px-6 py-20">
        <!-- Top Section -->
        <div class="grid lg:grid-cols-12 gap-12 mb-16">
            <!-- Brand Section - Takes more space -->
            <div class="lg:col-span-5">
                <div class="mb-8">
                    <a href="/" class="inline-flex items-center space-x-3 group">
                        <div class="relative">
                            <div class="absolute inset-0 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl blur opacity-50 group-hover:opacity-75 transition-opacity"></div>
                            <div class="relative w-12 h-12 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl flex items-center justify-center transform transition-all group-hover:scale-105 group-hover:rotate-3">
                                <span class="text-white font-bold text-2xl">S</span>
                            </div>
                        </div>
                        <span class="text-2xl font-bold text-white transition-colors group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-blue-400 group-hover:to-indigo-400 group-hover:bg-clip-text">Saasential</span>
                    </a>
                </div>
                <p class="text-gray-400 leading-relaxed text-lg mb-8 max-w-md">
                    Building next-gen software solutions for FinTech innovators worldwide.
                    From API design to global payment infrastructure — we make complex simple.
                </p>

                <!-- Newsletter -->
                <!--<div class="relative">
                    <h4 class="text-white font-semibold mb-3 text-sm uppercase tracking-wider">Stay Updated</h4>
                    <div class="flex gap-2">
                        <input
                                type="email"
                                placeholder="Enter your email"
                                class="flex-1 px-4 py-3 bg-gray-800/50 border border-gray-700 rounded-lg focus:outline-none focus:border-blue-500 transition-colors text-sm backdrop-blur-sm"
                        />
                        <button class="px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-lg font-medium hover:from-blue-500 hover:to-indigo-500 transition-all transform hover:scale-105 active:scale-95">
                            Subscribe
                        </button>
                    </div>
                </div>-->
            </div>

            <!-- Links Grid -->
            <div class="lg:col-span-7 grid grid-cols-2 md:grid-cols-3 gap-8">
                <!-- Quick Links -->
                <div>
                    <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-6 flex items-center gap-2">
                        <div class="w-1 h-4 bg-gradient-to-b from-blue-500 to-indigo-500 rounded-full"></div>
                        Navigation
                    </h3>
                    <ul class="space-y-3">
                        {footerLinks.map((link) => (
                                <li>
                                    <a
                                            href={link.href}
                                            class="text-gray-400 hover:text-blue-400 transition-colors duration-200 flex items-center gap-2 group"
                                    >
                                        <span class="w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:bg-blue-400 transition-colors"></span>
                                        {link.name}
                                    </a>
                                </li>
                        ))}
                    </ul>
                </div>

                <!-- Company -->
                <div>
                    <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-6 flex items-center gap-2">
                        <div class="w-1 h-4 bg-gradient-to-b from-blue-500 to-indigo-500 rounded-full"></div>
                        Company
                    </h3>
                    <ul class="space-y-3">
                        <li><a href="#" class="text-gray-400 hover:text-blue-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:bg-blue-400 transition-colors"></span>Careers</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-blue-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:bg-blue-400 transition-colors"></span>Blog</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-blue-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:bg-blue-400 transition-colors"></span>Press Kit</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-blue-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-1.5 rounded-full bg-gray-600 group-hover:bg-blue-400 transition-colors"></span>Partners</a></li>
                    </ul>
                </div>

                <!-- Connect -->
                <div>
                    <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-6 flex items-center gap-2">
                        <div class="w-1 h-4 bg-gradient-to-b from-blue-500 to-indigo-500 rounded-full"></div>
                        Connect
                    </h3>
                    <div class="grid grid-cols-2 gap-3 mb-6">
                        {socials.map((social) => (
                                <a
                                        href={social.href}
                                        class="group relative w-12 h-12 flex items-center justify-center rounded-xl bg-gray-800/50 border border-gray-700 hover:border-blue-500 backdrop-blur-sm transition-all duration-300 overflow-hidden"
                                >
                                    <div class="absolute inset-0 bg-gradient-to-br from-blue-600/20 to-indigo-600/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                    <Icon name={social.icon} class="w-5 h-5 text-gray-400 group-hover:text-blue-400 transition-colors relative z-10" />
                                </a>
                        ))}
                    </div>
                    <p class="text-gray-500 text-sm">
                        <Icon name="fa7-solid:envelope" class="w-4 h-4 inline mr-2 text-blue-400" />
                        hello@saasential.com
                    </p>
                </div>
            </div>
        </div>

        <!-- Divider -->
        <div class="relative mb-8">
            <div class="h-px bg-gradient-to-r from-transparent via-gray-700 to-transparent"></div>
            <div class="absolute inset-0 h-px bg-gradient-to-r from-transparent via-blue-500/50 to-transparent blur-sm"></div>
        </div>

        <!-- Bottom Bar -->
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
            <p class="text-gray-500">
                © {new Date().getFullYear()} <span class="text-gray-300 font-medium">Saasential</span>. Crafted with passion.
            </p>
            <div class="flex items-center gap-6">
                <a href="#" class="text-gray-500 hover:text-blue-400 transition-colors">Privacy Policy</a>
                <span class="text-gray-700">•</span>
                <a href="#" class="text-gray-500 hover:text-blue-400 transition-colors">Terms of Service</a>
                <span class="text-gray-700">•</span>
                <a href="#" class="text-gray-500 hover:text-blue-400 transition-colors">Cookies</a>
            </div>
        </div>
    </div>

    <!-- Bottom glow effect -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-500 to-transparent opacity-50"></div>
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-blue-500/5 to-transparent pointer-events-none"></div>
</footer>

<style>
    @keyframes pulse {
        0%, 100% {
            opacity: 0.1;
        }
        50% {
            opacity: 0.15;
        }
    }
</style>