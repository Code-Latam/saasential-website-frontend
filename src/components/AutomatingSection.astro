---
import {automationContent} from "../content/content";
---
<!-- Automating Qualification Process Section -->
<section id={automationContent.id} class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
        <!-- Header -->
        <div class="flex justify-between items-center mb-12 portfolio-header">
            <div>
                <div class="flex items-center gap-2 mb-3" data-aos="fade-up" data-aos-delay="100">
                    <span class="text-blue-400 text-lg">✱</span>
                    <span class="text-blue-400 font-semibold tracking-wide uppercase text-sm">
            {automationContent.subtitle}
          </span>
                    <span class="text-blue-400 text-lg">✱</span>
                </div>
                <h2 class="text-5xl font-bold text-gray-900" data-aos="fade-up" data-aos-delay="200">
                    {automationContent.title}
                </h2>
            </div>
        </div>

        <!-- Content -->
        <div class="space-y-6 max-w-5xl text-gray-600 text-lg leading-relaxed" data-aos="fade-up" data-aos-delay="400">
            {automationContent.content.map((item) => (
                    <p>
                        {item.text.split("API Astrolab").length > 1 ? (
                                <>
                                    {item.text.split("API Astrolab")[0]}
                                    <a href={item.link?.url} target="_blank" class="text-blue-600 font-semibold hover:underline">
                                        {item.link?.label}
                                    </a>
                                    {item.text.split("API Astrolab")[1]}
                                </>
                        ) : (
                            item.text
                        )}
                    </p>
            ))}
        </div>
    </div>
</section>
<style>
    section {
        scroll-margin-top: 80px;
    }

    /* AOS Animations */
    [data-aos] {
        opacity: 0;
        transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    [data-aos="fade-up"] {
        transform: translateY(40px);
    }

    [data-aos="fade-down"] {
        transform: translateY(-40px);
    }

    [data-aos="fade-left"] {
        transform: translateX(40px);
    }

    [data-aos="fade-right"] {
        transform: translateX(-40px);
    }

    [data-aos].aos-animate {
        opacity: 1;
        transform: translateY(0) translateX(0);
    }

    /* Smooth scrolling */
    html {
        scroll-behavior: smooth;
    }

    /* Smooth details transition */
    details {
        overflow: hidden;
    }

    details[open] summary {
        border-bottom: 1px solid #e5e7eb;
        margin-bottom: 1rem;
        padding-bottom: 1rem;
    }

    /* Remove default marker */
    summary::-webkit-details-marker {
        display: none;
    }

    /* Better line breaks for bullet points */
    .whitespace-pre-line {
        white-space: pre-line;
    }

</style>

<script>
    // Enhanced intersection observer with stagger effect
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const delay = entry.target.getAttribute('data-aos-delay') || 0;
                    setTimeout(() => {
                        entry.target.classList.add('aos-animate');
                    }, parseInt(delay.toString()));
                }
            });
        },
        {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        }
    );

    document.querySelectorAll('[data-aos]').forEach((el) => observer.observe(el));
</script>