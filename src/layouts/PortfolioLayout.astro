---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
import ContactSection from "../components/ContactSection.astro";
const { portfolios } = Astro.props;
import { Image } from 'astro:assets';

---
<Layout>
    <Navbar />

    <!-- ========== HERO SECTION ========== -->
    <section class="bg-white  min-h-screen flex flex-col">
        <div class="relative w-full h-[550px] mb-20">
            <div class="absolute inset-0 overflow-hidden bg-gradient-to-br from-gray-900 via-blue-900 to-black">
                <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e3a8a_1px,transparent_1px),linear-gradient(to_bottom,#1e3a8a_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-10"></div>

                <!-- Animated gradient orbs -->
                <div class="absolute inset-0">
                    <div class="absolute top-20 left-10 w-96 h-96 bg-blue-500 rounded-full mix-blend-screen filter blur-3xl opacity-20 animate-blob"></div>
                    <div class="absolute top-40 right-10 w-96 h-96 bg-indigo-500 rounded-full mix-blend-screen filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>
                    <div class="absolute bottom-20 left-1/2 w-96 h-96 bg-blue-600 rounded-full mix-blend-screen filter blur-3xl opacity-15 animate-blob animation-delay-4000"></div>
                </div>

                <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
            </div>

            <!-- Breadcrumb -->
            <div class="relative z-10 max-w-7xl mx-auto px-6 pt-32">
                <nav class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 backdrop-blur-lg border border-white/20 rounded-full text-sm text-white shadow-lg" data-aos="fade-down">
                    <a href="/" class="hover:text-blue-400 transition-colors flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                        </svg>
                        Home
                    </a>
                    <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <a href="/portfolio" class="hover:text-blue-400 transition-colors">Portfolio</a>
                    <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <span class="text-blue-400 font-medium">{portfolios.title}</span>
                </nav>
            </div>

            <!-- Hero Title -->
            <div class="relative z-10 max-w-7xl mx-auto px-6 mt-16">
                <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6" data-aos="fade-up" data-aos-delay="100">
                    {portfolios.title}
                </h1>

                <div class="flex items-center gap-6 text-white/80" data-aos="fade-up" data-aos-delay="200">
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                        </svg>
                        <a href={portfolios.url}
                           target="_blank"
                            rel="noopener noreferrer"
                           class="hover:text-white transition-colors hover:underline"
                        >{portfolios.client}</a>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        {portfolios.location}
                    </div>
                </div>

                <div class="h-1.5 w-24 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full mt-8" data-aos="fade-right" data-aos-delay="300"></div>
            </div>

            <!-- Scroll Down Arrow -->
            <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
                <div class="flex flex-col items-center gap-2 animate-bounce">
                    <span class="text-white/60 text-sm font-medium">Scroll Down</span>
                    <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- ========== MAIN CONTENT ========== -->
        <div class="max-w-7xl mx-auto px-6 py-12 grid lg:grid-cols-[1fr_380px] gap-12">
            <!-- Left Content -->
            <div class="space-y-16">
                <!-- Hero Image -->
                <div class="group relative overflow-hidden rounded-3xl shadow-2xl" data-aos="fade-up">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-500/20 to-indigo-500/20 rounded-3xl blur-2xl group-hover:blur-3xl transition-all"></div>
                    <Image height={400} width={400} src={portfolios.image} alt={portfolios.title} class="relative w-full object-cover rounded-3xl transform group-hover:scale-105 transition-transform duration-700" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>

                <!-- Challenge Section -->
                <div class="space-y-6" data-aos="fade-right">
                    <div class="flex items-center gap-4">
                        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">The Challenge</h2>
                    </div>
                    <div class="rounded-2xl p-8">
                        <p class="text-gray-700 leading-relaxed text-lg">{portfolios.challenge}</p>
                    </div>
                </div>

                <!-- Solution Section -->
                <div class="space-y-6" data-aos="fade-left">
                    <div class="flex items-center gap-4">
                        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Our Solution</h2>
                    </div>
                    <div class="rounded-2xl p-8">
                        <p class="text-gray-700 leading-relaxed text-lg">{portfolios.solution}</p>
                    </div>
                </div>

                <!-- Process Section -->
                <div class="space-y-8" data-aos="fade-up">
                    <div class="flex items-center gap-4">

                        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Development Process</h2>
                    </div>

                    <div class="space-y-6">
                        {portfolios.process.map((step:any, i:any) => (
                                <div
                                        class="group relative bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl border border-gray-200 hover:border-blue-300 transition-all duration-500"
                                        data-aos="fade-up"
                                        data-aos-delay={i * 100}
                                >
                                    <!-- Step Number -->
                                    <div class="absolute -left-4 top-8 w-12 h-12 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-lg group-hover:scale-110 group-hover:rotate-3 transition-all">
                                        {i + 1}
                                    </div>

                                    <!-- Progress Bar -->
                                    <div class="absolute left-0 top-0 w-1 h-full bg-gradient-to-b from-blue-500 to-indigo-500 transform scale-y-0 group-hover:scale-y-100 transition-transform origin-top rounded-l-2xl"></div>

                                    <div class="ml-12">
                                        <h4 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors">
                                            {step.title}
                                        </h4>
                                        <p class="text-gray-600 leading-relaxed">
                                            {step.desc}
                                        </p>
                                    </div>
                                </div>
                        ))}
                    </div>
                </div>

                <!-- Results Section -->
                <div class="space-y-8" data-aos="fade-up">
                    <div class="flex items-center gap-4">
                        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Measurable Results</h2>
                    </div>

                    <div class="grid md:grid-cols-3 gap-6">
                        {portfolios.results.map((result:any, i:any) => (
                                <div
                                        class="group relative bg-gradient-to-br from-purple-50 to-pink-50 border border-purple-200 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 overflow-hidden"
                                        data-aos="zoom-in"
                                        data-aos-delay={i * 100}
                                >
                                    <!-- Animated background -->
                                    <div class="absolute inset-0 bg-gradient-to-br from-purple-400/10 to-pink-400/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>

                                    <div class="relative">
                                        <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 group-hover:rotate-12 transition-all">
                                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                            </svg>
                                        </div>
                                        <h4 class="text-lg font-bold text-gray-900 mb-2">{result.title}</h4>
                                        <p class="text-gray-600 text-sm leading-relaxed">{result.desc}</p>
                                    </div>
                                </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Right Sidebar - Sticky -->
            <aside class="space-y-6">
                <div class="lg:sticky lg:top-32 space-y-6">
                    <!-- Project Info Card -->
                    <div class="bg-white border border-gray-200 rounded-2xl p-8 shadow-lg" data-aos="fade-left">
                        <div class="flex items-center gap-3 mb-6">

                            <h3 class="text-xl font-bold text-gray-900">Project Details</h3>
                        </div>

                        <div class="space-y-5">
                            <div class="pb-4 border-b border-gray-200">
                                <p class="text-sm text-gray-500 mb-1">Category</p>
                                <p class="font-semibold text-gray-900">{portfolios.category}</p>
                            </div>

                            <div class="pb-4 border-b border-gray-200">
                                <p class="text-sm text-gray-500 mb-1">Client</p>
                                <p class="font-semibold text-gray-900">{portfolios.client}</p>
                            </div>

                            <div class="pb-4 border-b border-gray-200">
                                <p class="text-sm text-gray-500 mb-1">Location</p>
                                <p class="font-semibold text-gray-900">{portfolios.location}</p>
                            </div>

                            <div class="pb-4 border-b border-gray-200">
                                <p class="text-sm text-gray-500 mb-1">Industry</p>
                                <p class="font-semibold text-gray-900">{portfolios.industry}</p>
                            </div>

                            <div>
                                <p class="text-sm text-gray-500 mb-3">Technology Stack</p>
                                <div class="flex flex-wrap gap-2">
                                    {portfolios.stack.map((tech:any) => (
                                            <span class="px-3 py-1.5 bg-gradient-to-r from-blue-50 to-indigo-50 text-blue-700 text-sm font-medium rounded-lg border border-blue-200">
                                            {tech}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- CTA Card -->
                    <div class="relative overflow-hidden bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-600 rounded-2xl p-8 shadow-xl" data-aos="fade-left" data-aos-delay="100">
                        <!-- Animated background pattern -->
                        <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff_1px,transparent_1px),linear-gradient(to_bottom,#ffffff_1px,transparent_1px)] bg-[size:2rem_2rem] opacity-10"></div>

                        <div class="relative">
                            <div class="w-14 h-14 bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center mb-6">
                                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                                </svg>
                            </div>

                            <h3 class="text-2xl font-bold text-white mb-3">Start Your Project</h3>
                            <p class="text-white/90 mb-6 leading-relaxed">
                                Let's bring your next big idea to life together. Get a free consultation today.
                            </p>

                            <a
                                    href="/book-meeting"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center justify-center gap-2 w-full bg-white text-blue-700 font-semibold px-6 py-4 rounded-xl hover:bg-blue-50 transition-all transform hover:scale-105 active:scale-95 shadow-lg"
                            >
                                Get a Free Quote
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                    </div>
            </aside>
        </div>
    </section>

    <ContactSection />
    <Footer />
</Layout>

<style>
    /* Blob Animation */
    @keyframes blob {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }
        33% {
            transform: translate(30px, -50px) scale(1.1);
        }
        66% {
            transform: translate(-20px, 20px) scale(0.9);
        }
    }

    .animate-blob {
        animation: blob 10s infinite;
    }

    .animation-delay-2000 {
        animation-delay: 2s;
    }

    .animation-delay-4000 {
        animation-delay: 4s;
    }

    /* AOS Animations */
    [data-aos] {
        opacity: 0;
        transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    [data-aos="fade-up"] {
        transform: translateY(40px);
    }

    [data-aos="fade-down"] {
        transform: translateY(-40px);
    }

    [data-aos="fade-left"] {
        transform: translateX(40px);
    }

    [data-aos="fade-right"] {
        transform: translateX(-40px);
    }

    [data-aos="zoom-in"] {
        transform: scale(0.9);
    }

    [data-aos].aos-animate {
        opacity: 1;
        transform: translateY(0) translateX(0) scale(1);
    }

    /* Smooth scrolling */
    html {
        scroll-behavior: smooth;
    }
</style>

<script>
    // Enhanced intersection observer with stagger effect
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const delay = entry.target.getAttribute('data-aos-delay') || 0;
                    setTimeout(() => {
                        entry.target.classList.add('aos-animate');
                    }, parseInt(delay.toString()));
                }
            });
        },
        {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        }
    );

    document.querySelectorAll('[data-aos]').forEach((el) => observer.observe(el));
</script>