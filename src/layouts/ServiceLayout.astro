---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import {Icon} from 'astro-icon/components'
import ContactSection from "../components/ContactSection.astro";
const { service } = Astro.props;
import { Image } from 'astro:assets';

---

<Layout>
<Navbar/>
<section class="bg-white  min-h-screen flex flex-col">

    <!-- ===== Hero Header ===== -->
    <div class="relative w-full h-[500px] mb-20">
        <div class="absolute inset-0 overflow-hidden bg-gradient-to-br from-gray-900 via-blue-900 to-black">
            <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e3a8a_1px,transparent_1px),linear-gradient(to_bottom,#1e3a8a_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-10"></div>

            <!-- Animated gradient orbs -->
            <div class="absolute inset-0">
                <div class="absolute top-20 left-10 w-96 h-96 bg-blue-500 rounded-full mix-blend-screen filter blur-3xl opacity-20 animate-blob"></div>
                <div class="absolute top-40 right-10 w-96 h-96 bg-indigo-500 rounded-full mix-blend-screen filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>
                <div class="absolute bottom-20 left-1/2 w-96 h-96 bg-blue-600 rounded-full mix-blend-screen filter blur-3xl opacity-15 animate-blob animation-delay-4000"></div>
            </div>

            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
        </div>

        <!-- Breadcrumb -->
        <div class="relative z-10 max-w-7xl mx-auto px-6 pt-32">
            <nav class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 backdrop-blur-lg border border-white/20 rounded-full text-sm text-white shadow-lg" data-aos="fade-down">
                <a href="/" class="hover:text-blue-400 transition-colors flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                    Home
                </a>
                <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <a href="/services" class="hover:text-blue-400 transition-colors">Services</a>
                <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <span class="text-blue-400 font-medium">{service.title}</span>
            </nav>
        </div>

        <!-- Hero Title -->
        <div class="relative z-10 max-w-7xl mx-auto px-6 mt-16">
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6" data-aos="fade-up" data-aos-delay="100">
                {service.title}
            </h1>
            <div class="h-1.5 w-24 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full" data-aos="fade-right" data-aos-delay="200"></div>
        </div>

        <!-- Scroll Down Arrow -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
            <div class="flex flex-col items-center gap-2 animate-bounce">
                <span class="text-white/60 text-sm font-medium">Scroll Down</span>
                <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                </svg>
            </div>
        </div>
    </div>

    <!-- ===== Intro Section (50/50 layout with multi-column points) ===== -->
    <div class="max-w-7xl mx-auto px-6 py-20">
        <div class="flex flex-col lg:flex-row items-start gap-16">
            <!-- Left Content -->
            <div class="lg:w-1/2 space-y-8" data-aos="fade-right">
                <!--<div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-100 text-blue-700 rounded-full text-sm font-semibold">
                    <span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span>
                    Our Expertise
                </div>-->

                <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
                    {service.title}
                </h2>

                <p class="text-gray-600 text-lg leading-relaxed">
                    {service.description}
                </p>

                <!-- Multi-column Points List -->
                <div class="grid sm:grid-cols-2 gap-4 pt-4">
                    {service.points.map((point, i) => (
                            <div
                                    class="flex items-center gap-3 p-4 bg-white rounded-xl transition-all duration-300 group"
                                    data-aos="fade-up"
                                    data-aos-delay={i * 50}
                            >
                                <div class="flex-shrink-0 w-3 h-3 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center mt-0.5 group-hover:scale-110 transition-transform">
                                </div>
                                <span class="text-gray-700 font-medium leading-snug">{point.title}</span>
                            </div>
                    ))}
                </div>

            </div>

            <!-- Right Image -->
            <div class="lg:w-1/2 flex justify-center" data-aos="fade-left">
                <div class="relative group">
                    <!-- Glow effect -->
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-500/20 to-indigo-500/20 rounded-3xl blur-2xl group-hover:blur-3xl transition-all"></div>

                    <!-- Image container -->
                    <div class="relative overflow-hidden rounded-3xl shadow-2xl border border-gray-200 transform group-hover:scale-[1.02] transition-transform duration-500">
                        <Image
                                src={service.image}
                                alt={service.title}
                                height={400}
                                width={600}
                                class="w-full h-full object-cover"
                        />
                        <!-- Overlay gradient -->
                        <div class="absolute inset-0 bg-gradient-to-t from-blue-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Process Section with Sticky Heading ===== -->
    <div class="relative bg-white py-24">
        <!-- Background decoration -->
        <div class="absolute top-0 left-0 w-full h-px"></div>

        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col lg:flex-row gap-16">
                <!-- Sticky Heading -->
                <div class="lg:w-2/5">
                    <div class="lg:sticky lg:top-32 space-y-6" data-aos="fade-right">
                        <!--<div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-100 text-blue-700 rounded-full text-sm font-semibold">
                            <span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span>
                            How We Work
                        </div>-->

                        <h3 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
                            Our Process
                        </h3>

                        <p class="text-gray-600 text-lg leading-relaxed">
                            Discover how our team ensures top-notch execution with precision and innovation at every stage of your project.
                        </p>

                        <!-- Stats -->
                        <div class="grid grid-cols-2 gap-6 pt-4">
                            <div class="space-y-1">
                                <div class="text-3xl font-bold text-blue-600">100%</div>
                                <div class="text-sm text-gray-600">Client Satisfaction</div>
                            </div>
                            <div class="space-y-1">
                                <div class="text-3xl font-bold text-blue-600">24/7</div>
                                <div class="text-sm text-gray-600">Support Available</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Scrollable Process Steps -->
                <div class="lg:w-3/5 space-y-6">
                    {service.points.map((point, i) => (
                            <div
                                    class="group relative bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl border border-gray-200 hover:border-blue-300 transition-all duration-500 overflow-hidden"
                                    data-aos="fade-up"
                                    data-aos-delay={i * 100}
                            >
                                <!-- Step number badge -->
                                <div class="absolute -right-4 -top-4 w-24 h-24 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-full flex items-center justify-center text-4xl font-bold text-blue-200 group-hover:scale-110 transition-transform">
                                    {String(i + 1).padStart(2, '0')}
                                </div>

                                <!-- Gradient bar -->
                                <div class="absolute left-0 top-0 w-1 h-full bg-gradient-to-b from-blue-500 to-indigo-500 transform scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>

                                <div class="relative">
                                    <!-- Icon -->
                                    <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 group-hover:rotate-3 transition-all">
                                        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                                        </svg>
                                    </div>

                                    <h4 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors">
                                        {point.title}
                                    </h4>

                                    <p class="text-gray-600 leading-relaxed">
                                        {point.desc}
                                    </p>
                                </div>
                            </div>
                    ))}
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Tools & Technologies Section ===== -->
    <div class="bg-white py-24">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-start mb-16" data-aos="fade-up">
                <!--<div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-100 text-blue-700 rounded-full text-sm font-semibold mb-6">
                    <span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span>
                    Technology Stack
                </div>-->

                <h3 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
                    Our Tools & Technologies
                </h3>

                <p class="text-gray-600 text-lg max-w-2xl">
                    We leverage cutting-edge technologies to deliver exceptional results
                </p>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-8" data-aos="fade-up" data-aos-delay="200">
                {service.tools.map((tool, i) => (
                        <div
                                class="group flex flex-col items-center justify-center p-6 bg-gradient-to-br from-blue-50 to-white rounded-2xl border border-gray-200 hover:border-blue-300 hover:shadow-lg transition-all duration-300 cursor-pointer"
                                data-aos="zoom-in"
                                data-aos-delay={i * 50}
                        >
                            <div class="w-16 h-16 mb-4 flex items-center justify-center transform group-hover:scale-110 group-hover:-rotate-6 transition-transform duration-300">
                                <img src={tool.icon} alt={tool.name} class="w-full h-full object-contain" />
                            </div>
                            <p class="text-gray-700 font-semibold text-sm text-center group-hover:text-blue-600 transition-colors">
                                {tool.name}
                            </p>
                        </div>
                ))}
            </div>
        </div>
    </div>

</section>

<style>
    /* AOS Animations */
    [data-aos] {
        opacity: 0;
        transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    [data-aos="fade-up"] {
        transform: translateY(40px);
    }

    [data-aos="fade-down"] {
        transform: translateY(-40px);
    }

    [data-aos="fade-left"] {
        transform: translateX(40px);
    }

    [data-aos="fade-right"] {
        transform: translateX(-40px);
    }

    [data-aos="zoom-in"] {
        transform: scale(0.9);
    }

    [data-aos].aos-animate {
        opacity: 1;
        transform: translateY(0) translateX(0) scale(1);
    }

    /* Blob Animation */
    @keyframes blob {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }
        33% {
            transform: translate(30px, -50px) scale(1.1);
        }
        66% {
            transform: translate(-20px, 20px) scale(0.9);
        }
    }

    .animate-blob {
        animation: blob 10s infinite;
    }

    .animation-delay-2000 {
        animation-delay: 2s;
    }

    .animation-delay-4000 {
        animation-delay: 4s;
    }

    /* Smooth scroll behavior */
    html {
        scroll-behavior: smooth;
    }
</style>

<ContactSection/>
<Footer/>
</Layout>
<script>
    // Enhanced intersection observer with stagger effect
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const delay = entry.target.getAttribute('data-aos-delay') || 0;
                    setTimeout(() => {
                        entry.target.classList.add('aos-animate');
                    }, parseInt(delay));
                }
            });
        },
        {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        }
    );

    document.querySelectorAll('[data-aos]').forEach((el) => observer.observe(el));
</script>