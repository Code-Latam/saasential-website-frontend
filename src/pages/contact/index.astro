---
import '../../styles/global.css';
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import ContactSection from "../../components/ContactSection.astro";
import Footer from "../../components/Footer.astro";
import SEO from "../../components/SEO.astro";
---
<SEO
    title="Contact Us | Saasential"
    description="Get in touch with Saasential for expert SaaS development, FinTech solutions, and software consulting services tailored to your business needs."
    keywords="Contact Saasential, SaaS development inquiry, FinTech consulting contact, software consulting services, API integration support"
    image="/logo/saasential_logo.svg"
    url="https://saasential.com/contact"
/>
<Layout>
    <Navbar/>
    <section class="bg-white min-h-screen flex flex-col">

        <!-- ===== Hero Header ===== -->
        <div class="relative w-full h-[500px] mb-20">
            <div class="absolute inset-0 overflow-hidden bg-gradient-to-br from-gray-900 via-blue-900 to-black">
                <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e3a8a_1px,transparent_1px),linear-gradient(to_bottom,#1e3a8a_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-10"></div>

                <!-- Animated gradient orbs -->
                <div class="absolute inset-0">
                    <div class="absolute top-20 left-10 w-96 h-96 bg-blue-500 rounded-full mix-blend-screen filter blur-3xl opacity-20 animate-blob"></div>
                    <div class="absolute top-40 right-10 w-96 h-96 bg-indigo-500 rounded-full mix-blend-screen filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>
                    <div class="absolute bottom-20 left-1/2 w-96 h-96 bg-blue-600 rounded-full mix-blend-screen filter blur-3xl opacity-15 animate-blob animation-delay-4000"></div>
                </div>

                <!-- Gradient overlay -->
                <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
            </div>

            <!-- Breadcrumb -->
            <div class="relative z-10 max-w-7xl mx-auto px-6 pt-32">
                <nav class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 backdrop-blur-lg border border-white/20 rounded-full text-sm text-white shadow-lg" data-aos="fade-down">
                    <a href="/" class="hover:text-blue-400 transition-colors flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                        </svg>
                        Home
                    </a>
                    <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <a href="/contact" class="text-blue-400 font-medium">Contact</a>
                </nav>
            </div>

            <!-- Hero Title -->
            <div class="relative z-10 max-w-7xl mx-auto px-6 mt-8">

                <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6" data-aos="fade-up" data-aos-delay="100">
                    Get in <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">Touch</span>
                </h1>

                <p class="text-xl text-white/80 max-w-2xl mb-8" data-aos="fade-up" data-aos-delay="200">
                    We're here to help! Whether you have questions about our services, need support, or want to discuss a project, feel free to reach out.
                </p>

                <div class="h-1.5 w-24 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full" data-aos="fade-right" data-aos-delay="300"></div>
            </div>

            <!-- Scroll Down Arrow -->
            <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
                <div class="flex flex-col items-center gap-2 animate-bounce">
                    <span class="text-white/60 text-sm font-medium">Scroll Down</span>
                    <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- ===== Contact Info Cards ===== -->
        <div class="max-w-7xl mx-auto px-6 pb-20">
            <div class="text-center mb-16" data-aos="fade-up">
                <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4">
                    Contact Information
                </h2>
            </div>

            <!-- Contact Cards Grid -->
            <div class="grid md:grid-cols-3 gap-8 mb-20">
                <!-- Email Card -->
                <div
                        class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl border border-gray-200 hover:border-blue-300 p-8 transition-all duration-500 relative overflow-hidden"
                        data-aos="fade-up"
                        data-aos-delay="100"
                >
                    <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-blue-500/10 to-indigo-500/10 rounded-full blur-2xl group-hover:scale-150 transition-transform"></div>

                    <div class="relative">
                        <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-6 transition-all">
                            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                            </svg>
                        </div>

                        <h3 class="text-xl font-bold text-gray-900 mb-2">Email Us</h3>
                        <p class="text-gray-600 mb-4">Send us an email anytime</p>

                        <a href="mailto:info@saasential.com" class="text-blue-600 hover:text-blue-700 font-semibold text-lg transition-colors flex items-center gap-2">
                            info@saasential.com
                            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Phone Card -->
                <div
                        class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl border border-gray-200 hover:border-blue-300 p-8 transition-all duration-500 relative overflow-hidden"
                        data-aos="fade-up"
                        data-aos-delay="200"
                >
                    <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-green-500/10 to-emerald-500/10 rounded-full blur-2xl group-hover:scale-150 transition-transform"></div>

                    <div class="relative">
                        <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-6 transition-all">
                            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                            </svg>
                        </div>

                        <h3 class="text-xl font-bold text-gray-900 mb-2">Call Us</h3>
                        <p class="text-gray-600 mb-4">Mon-Fri from 9am to 6pm</p>

                        <a href="tel:+13073945087" class="text-blue-600 hover:text-blue-700 font-semibold text-lg transition-colors flex items-center gap-2">
                            +1 307 394 5087
                            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Location Card -->
                <div
                        class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl border border-gray-200 hover:border-blue-300 p-8 transition-all duration-500 relative overflow-hidden"
                        data-aos="fade-up"
                        data-aos-delay="300"
                >
                    <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-full blur-2xl group-hover:scale-150 transition-transform"></div>

                    <div class="relative">
                        <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-6 transition-all">
                            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900 mb-2">Visit Us</h3>
                        <p class="text-gray-600 mb-4">Casper, Wyoming</p>

                        <a href="https://maps.google.com/?q=5830+E+2nd+St,+Ste+7000+19416,+Casper,+Wyoming+82609" target="_blank" class="text-blue-600 hover:text-blue-700 font-semibold transition-colors flex items-center gap-2">
                            View on Map
                            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- ===== Office Location Section ===== -->
            <div class="grid lg:grid-cols-2 gap-12 items-start mb-20">
                <!-- Left: Office Details -->
                <div class="space-y-8" data-aos="fade-right">
                    <div>
                        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                            Visit Our Headquarters
                        </h2>

                        <p class="text-gray-600 text-lg leading-relaxed mb-8">
                            Located in the heart of Casper, Wyoming, our office is equipped with modern facilities to serve you better. We welcome visitors by appointment.
                        </p>
                    </div>

                    <!-- Address Card -->
                    <div class="bg-white to-indigo-50 border border-blue-200 rounded-2xl p-8">
                        <div class="flex items-start gap-4 mb-6">
                            <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-2">Office Address</h3>
                                <p class="text-gray-700 leading-relaxed">
                                    5830 E 2nd St, Ste 7000 #19416<br/>
                                    Casper, Wyoming 82609<br/>
                                    United States
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white to-indigo-50 border border-blue-200 rounded-2xl p-8">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 mb-3">Working Hours</h3>
                                <div class="space-y-2 text-gray-700">
                                    <div class="flex items-center justify-between">
                                        <span class="font-semibold">Monday – Friday</span>
                                        <span>9:00 AM – 6:00 PM</span>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="font-semibold">Weekend</span>
                                        <span class="text-red-500 font-semibold">Closed</span>
                                    </div>
                                    <p class="text-sm text-gray-600 mt-2 pt-2 border-t border-green-200">
                                        Timezone: UTC-5 (Eastern Time)
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Right: Google Map -->
                <div class="space-y-6" data-aos="fade-left">
                    <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-gray-200 group">
                        <div class="absolute inset-0 bg-gradient-to-br from-blue-500/20 to-indigo-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all"></div>
                        <div class="relative">
                            <iframe
                                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2979.8285642847657!2d-106.31343892347647!3d42.8666389711423!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x876f5f8f8f8f8f8f%3A0x8f8f8f8f8f8f8f8f!2s5830%20E%202nd%20St%2C%20Casper%2C%20WY%2082609!5e0!3m2!1sen!2sus!4v1701234567890!5m2!1sen!2sus"
                                    width="100%"
                                    height="500"
                                    style="border:0;"
                                    allowfullscreen=""
                                    loading="lazy"
                                    referrerpolicy="no-referrer-when-downgrade"
                                    class="rounded-2xl"
                            ></iframe>
                        </div>
                    </div>

                    <!-- Map Info Card -->
                    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-md">
                        <div class="flex items-center justify-between">
                            <div>
                                <h4 class="font-bold text-gray-900 mb-1">Need Directions?</h4>
                                <p class="text-sm text-gray-600">Get turn-by-turn navigation</p>
                            </div>
                            <a
                                    href="https://maps.google.com/?q=5830+E+2nd+St,+Ste+7000+19416,+Casper,+Wyoming+82609"
                                    target="_blank"
                                    class="px-5 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-medium rounded-xl hover:from-blue-500 hover:to-indigo-500 transition-all transform hover:scale-105 active:scale-95 shadow-lg flex items-center gap-2"
                            >
                                Open Map
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <ContactSection/>
    <Footer/>
</Layout>

<style>
    /* Blob Animation */
    @keyframes blob {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }
        33% {
            transform: translate(30px, -50px) scale(1.1);
        }
        66% {
            transform: translate(-20px, 20px) scale(0.9);
        }
    }

    .animate-blob {
        animation: blob 10s infinite;
    }

    .animation-delay-2000 {
        animation-delay: 2s;
    }

    .animation-delay-4000 {
        animation-delay: 4s;
    }

    /* AOS Animations */
    [data-aos] {
        opacity: 0;
        transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    [data-aos="fade-up"] {
        transform: translateY(40px);
    }

    [data-aos="fade-down"] {
        transform: translateY(-40px);
    }

    [data-aos="fade-left"] {
        transform: translateX(40px);
    }

    [data-aos="fade-right"] {
        transform: translateX(-40px);
    }

    [data-aos].aos-animate {
        opacity: 1;
        transform: translateY(0) translateX(0);
    }

    /* Smooth scrolling */
    html {
        scroll-behavior: smooth;
    }
</style>

<script>
    // Enhanced intersection observer with stagger effect
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const delay = entry.target.getAttribute('data-aos-delay') || 0;
                    setTimeout(() => {
                        entry.target.classList.add('aos-animate');
                    }, parseInt(delay.toString()));
                }
            });
        },
        {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        }
    );

    document.querySelectorAll('[data-aos]').forEach((el) => observer.observe(el));
</script>