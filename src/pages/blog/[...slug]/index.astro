---
// src/pages/blog/[...slug]/index.astro
// This catches ALL /blog/* URLs and serves the same page

// Import your existing layout
import Layout from "../../../layouts/Layout.astro";

// Disable prerendering - this is critical for client-side routing
export const prerender = false;

// Get the slug from the URL (if any)
const slug = Astro.params.slug;
---

<Layout title="Blog | SaaSential" description="Insights on FinTech SaaS, AI sales agents, and API development">
  <main class="min-h-screen py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          Blog
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Insights on FinTech SaaS, AI sales agents, API development, and building sellable products
        </p>
      </div>

      <!-- Widget Container -->
      <div id="meeting-maker-widget"></div>
      
      <!-- Script with token -->
      <script 
        src="https://api.meetingmaker.tech/widgets/embed.js"
        data-token="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI2OWQ3OWJjODE1NjdhM2RjODcyYzI0YzIiLCJjbGllbnRJZCI6IjY5ZDc5YmM4MTU2N2EzZGM4NzJjMjRjMCIsInJvbGUiOiJvd25lciIsImlhdCI6MTc3NTczNzgwMCwiZXhwIjoxOTAxOTY4MjAwfQ.N49bDXdG4rF-3ryJRx9rMdTh2Mhhab8llfFzIvjr4z4"
